{% extends 'base.html.twig' %}

{% block body %}
<style>
    /* Styles globaux */
    body { background-color: #121214; color: white; font-family: sans-serif; margin: 0; padding: 0; }
    .header { display: flex; justify-content: space-between; padding: 20px; align-items: center; }
    .btn-purple { background: #6366f1; color: white; padding: 10px 20px; border-radius: 5px; text-decoration: none; border: none; cursor: pointer; display: inline-block; }
    .import-banner { background: #1a1a1e; border: 1px dashed #333; padding: 40px; border-radius: 15px; text-align: center; margin: 20px; }
    
    /* --- NOUVEAU : SYSTEME D'ONGLETS (NAVIGATION) --- */
    .nav-tabs { display: flex; gap: 20px; margin-left: 20px; }
    .tab-link { color: #9ca3af; font-size: 18px; font-weight: bold; text-decoration: none; cursor: pointer; padding-bottom: 5px; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .tab-link.active { color: #6366f1; border-bottom-color: #6366f1; }
    
    /* Gestion de l'affichage des sections */
    .page-section { display: none; }
    .page-section.active { display: block; }

    /* Grille d'albums */
    .album-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 20px; }
    .album-card { background: #1a1a1e; padding: 10px; border-radius: 10px; cursor: pointer; transition: transform 0.2s; }
    .album-card:hover { transform: scale(1.02); }
    .album-card img { width: 100%; height: 200px; object-fit: cover; border-radius: 8px; }
    
    /* SYSTEME DE MODALES (POP-UPS) */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.8);
        display: flex; justify-content: center; align-items: center;
        z-index: 1000;
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .modal-overlay.active { opacity: 1; pointer-events: auto; }

    .form-container {
        max-width: 800px; width: 90%; max-height: 85vh; overflow-y: auto;
        background: #1a1a1e; padding: 30px; border-radius: 15px;
        position: relative; box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }
    .close-modal { position: absolute; top: 15px; right: 20px; background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; opacity: 0.7; }
    .close-modal:hover { opacity: 1; }

    /* Formulaire styles */
    .field { margin-bottom: 14px; }
    input, select, textarea { width: 100%; background: #121214; color: #fff; padding: 10px; border-radius: 8px; border: 1px solid #2a2a2a; box-sizing: border-box; }
    .row { display: flex; gap: 14px; }
    .row > * { flex: 1; }

    /* Détails Album et Avis */
    .detail-flex { display: flex; gap: 25px; }
    .detail-img { width: 250px; height: 250px; object-fit: cover; border-radius: 10px; }
    .review-card { background: #121214; padding: 12px; border-radius: 8px; margin-top: 10px; border: 1px solid #2a2a2a; }
    .stars { color: #f59e0b; }
    .artist-clickable-link { color: #6366f1; cursor: pointer; text-decoration: underline; }

    /* --- STYLE DU FOOTER & MODALE MENTIONS --- */
    .main-footer { background-color: #1a1a1e; border-top: 1px solid #2a2a2a; padding: 25px 0; margin-top: 50px; }
    .footer-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 20px; font-size: 14px; opacity: 0.8; }
    .footer-links .footer-link { color: white; text-decoration: none; margin-left: 20px; transition: color 0.2s; }
    .footer-links .footer-link:hover { color: #6366f1; }
    .footer-modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.85); display: flex; justify-content: center; align-items: center; z-index: 2000; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    .footer-modal-overlay:target { opacity: 1; pointer-events: auto; }
    .footer-modal-box { max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto; background: #1a1a1e; padding: 30px; border-radius: 15px; position: relative; border: 1px solid #2a2a2a; text-align: left; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .footer-modal-box h3 { color: #fff; font-size: 16px; margin-top: 20px; margin-bottom: 5px; }
    .footer-modal-box p { font-size: 14px; opacity: 0.7; line-height: 1.5; margin-top: 0; }
    .footer-close-modal { position: absolute; top: 15px; right: 20px; text-decoration: none; color: #fff; font-size: 28px; opacity: 0.7; transition: opacity 0.2s; }
    .footer-close-modal:hover { opacity: 1; }
    
    @media (max-width: 600px) {
        .footer-content { flex-direction: column; gap: 15px; text-align: center; }
        .footer-links .footer-link { margin: 0 10px; }
    }
</style>

<div class="container">
    {# 1. BARRE DE NAVIGATION #}
    <header class="header">
        <div class="logo"><h2>Juke-box</h2></div>
        
        {# Liens de basculement entre Accueil et Bibliothèque #}
        <div class="nav-tabs">
            <span class="tab-link active" onclick="switchTab('home-section')">Accueil</span>
            <span class="tab-link" onclick="switchTab('library-section')">Bibliothèque</span>
        </div>

        <div class="auth-buttons">
            {% if app.user %}
                <span style="margin-right: 15px;">Bonjour {{ app.user.username }}</span>
                <a href="/logout" class="btn-purple">Déconnexion</a>
            {% else %}
                <a href="/login" style="color: white; margin-right: 15px; text-decoration: none;">Connexion</a>
                <a href="/register" class="btn-purple">S'inscrire</a>
            {% endif %}
        </div>
    </header>

    {# ---------------------------------------------------- #}
    {# SECTION 1 : ACCUEIL (VUE PRINCIPALE)                #}
    {# ---------------------------------------------------- #}
    <div id="home-section" class="page-section active">
        {# ZONE D'IMPORT (Bannière) #}
        <div class="import-banner">
            <p>Ajoutez un album, un artiste ou laissez un avis général</p>
            <button id="openModalBtn" class="btn-purple" style="margin-top: 10px;">Importer un album</button>
        </div>

        <h3 style="margin-left: 20px;">Avis récent</h3>
        <div class="album-grid">
            {# On affiche une sélection restreinte (les 4 premiers) sur la Home #}
            {% for album in albums|slice(0, 4) %}
                <div class="album-card" onclick="openAlbumDetails({{ {
                    id: album.id,
                    title: album.title,
                    coverUrl: album.coverUrl,
                    artistId: album.artist.id,
                    artistName: album.artist.name,
                    reviews: album.reviews|map(r => {id: r.id, user: r.user.username, rating: r.rating, text: r.text})
                }|json_encode|e('html_attr') }}, {{ app.user ? 'true' : 'false' }})">
                    
                    <img src="{{ album.coverUrl }}" alt="Cover">
                    <h4>{{ album.title }}</h4>
                    <p style="opacity: 0.7; margin: 5px 0 0 0;">Par : <span class="artist-clickable-link" onclick="event.stopPropagation(); openArtistDetails({{ album.artist.id }}, '{{ album.artist.name|e('js') }}')">{{ album.artist.name }}</span></p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# SECTION 2 : LA BIBLIOTHÈQUE DEMANDÉE PAR LE PROF      #}
    {# ---------------------------------------------------- #}
    <div id="library-section" class="page-section">
        <div style="padding: 20px; background: #1a1a1e; margin: 20px; border-radius: 15px;">
            <h2 style="margin-top: 0; color: #6366f1;">Ma Bibliothèque</h2>
            <p style="opacity: 0.7;">Explorez l'intégralité de notre catalogue musical..</p>
            {# La barre de recherche est centralisée ici, à l'intérieur de l'espace bibliothèque #}
            <input type="text" id="searchInput" placeholder="Rechercher un album ou un artiste dans la bibliothèque..." style="margin-top: 15px;">
        </div>

        {# C'est ici que réside la fameuse "1 card dupliquée automatiquement" #}
        <div class="album-grid" id="mainAlbumGrid">
            {% for album in albums %}
                <div class="album-card" 
                     data-title="{{ album.title|lower }}" 
                     data-artist="{{ album.artist.name|lower }}"
                     onclick="openAlbumDetails({{ {
                        id: album.id,
                        title: album.title,
                        coverUrl: album.coverUrl,
                        artistId: album.artist.id,
                        artistName: album.artist.name,
                        reviews: album.reviews|map(r => {id: r.id, user: r.user.username, rating: r.rating, text: r.text})
                    }|json_encode|e('html_attr') }}, {{ app.user ? 'true' : 'false' }})">
                    
                    <img src="{{ album.coverUrl }}" alt="Cover">
                    <h4>{{ album.title }}</h4>
                    <p style="opacity: 0.7; margin: 5px 0 0 0;">
                        Par : <span class="artist-clickable-link" onclick="event.stopPropagation(); openArtistDetails({{ album.artist.id }}, '{{ album.artist.name|e('js') }}')">{{ album.artist.name }}</span>
                    </p>
                    
                    {% if is_granted('ROLE_ADMIN') %}
                        <button style="color: red; background: none; border: none; cursor: pointer; margin-top: 10px;">Supprimer</button>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 1 : FORMULAIRE D'AJOUT D'ALBUM                #}
    {# ---------------------------------------------------- #}
    <div id="albumModal" class="modal-overlay">
        <div class="form-container">
            <button class="close-modal" onclick="closeModal('albumModal')">&times;</button>
            <h2 style="margin-top:0;">Importer / Ajouter un album</h2>
            <form action="/album/new" method="post">
                <div class="row">
                    <div class="field">
                        <label>Titre</label>
                        <input name="title" type="text" required placeholder="Ex: Random Access Memories" />
                    </div>
                    <div class="field">
                        <label>Date de sortie</label>
                        <input name="release_date" type="date" />
                    </div>
                </div>
                <div class="field">
                    <label>Cover URL</label>
                    <input name="cover_url" type="url" required placeholder="https://..." />
                </div>
                <div class="field">
                    <label>Artiste</label>
                    <select name="artist_id">
                        <option value="">-- Choisir (optionnel) --</option>
                        {% for artist in artists %}
                            <option value="{{ artist.id }}">{{ artist.name }}</option>
                        {% endfor %}
                    </select>
                    <input name="artist_name" type="text" placeholder="Ou créez un artiste : Ex: Daft Punk" style="margin-top: 8px;" />
                </div>
                <hr style="border:0; border-top:1px solid #2a2a2a; margin: 18px 0;" />
                <h3>Laisser un avis (SQL)</h3>
                <div class="row">
                    <div class="field">
                        <label>Note (1-5)</label>
                        <select name="rating" required>
                            <option value="" disabled selected>Choisir une note</option>
                            {% for i in 1..5 %} <option value="{{ i }}">{{ i }}</option> {% endfor %}
                        </select>
                    </div>
                    <div class="field">
                        <label>Texte</label>
                        <textarea name="text" rows="3" placeholder="Votre avis..." required></textarea>
                    </div>
                </div>
                <button type="submit" class="btn-purple" style="margin-top: 10px;">Créer et Ajouter l'album</button>
            </form>
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 2 : DETAILS DE L'ALBUM ET SES AVIS            #}
    {# ---------------------------------------------------- #}
    <div id="showAlbumModal" class="modal-overlay">
        <div class="form-container" id="showAlbumContent">
            <button class="close-modal" onclick="closeModal('showAlbumModal')">&times;</button>
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 3 : DISCOGRAPHIE DE L'ARTISTE                 #}
    {# ---------------------------------------------------- #}
    <div id="showArtistModal" class="modal-overlay">
        <div class="form-container">
            <button class="close-modal" onclick="closeModal('showArtistModal')">&times;</button>
            <h2 id="artistModalTitle" style="margin-top:0;"></h2>
            <h3>Discographie</h3>
            <div class="album-grid" id="artistAlbumsGrid" style="padding:0;"></div>
        </div>
    </div>
</div>

{# --- FOOTER DU SITE --- --> #}
<footer class="main-footer">
    <div class="footer-content">
        <p>&copy; {{ "now"|date("Y") }} <span style="color: #6366f1; font-weight: bold;">Juke-box</span>. Tous droits réservés.</p>
        <nav class="footer-links">
            <a href="#modal-mentions" class="footer-link">Mentions Légales</a>
            <a href="#" class="footer-link">Contact</a>
        </nav>
    </div>
</footer>

{# --- MODALE DES MENTIONS LÉGALES (PUR CSS) --- #}
<div id="modal-mentions" class="footer-modal-overlay">
    <div class="footer-modal-box">
        <a href="#" class="footer-close-modal">&times;</a>
        <h2 style="margin-top: 0; color: #6366f1;">Mentions Légales</h2>
        <hr style="border: 0; border-top: 1px solid #2a2a2a; margin: 15px 0;">
        <h3>1. Éditeur du projet</h3>
        <p>Le site <strong>Juke-box</strong> est une application web fictive réalisée dans le cadre d'un projet de développement informatique. Édité de manière artisanale sur un MacBook Air.</p>
        <h3>2. Hébergement</h3>
        <p>Ce site est propulsé localement en environnement de développement à l'adresse <code>127.0.0.1:8000</code>. La persistance des données utilise un serveur relationnel MySQL (via phpMyAdmin) couplé à une base de données NoSQL MongoDB.</p>
        <h3>3. Sécurité et Données</h3>
        <p>Les données d'authentification des comptes utilisateurs sont hachées selon les standards de sécurité natifs de Symfony. Le formulaire d'inscription intègre un dispositif de protection par jeton CSRF et un mécanisme de filtrage invisible (Honeypot) contre les requêtes automatisées.</p>
        <div style="text-align: right; margin-top: 25px;">
            <a href="#" class="btn-purple" style="font-size: 14px;">Fermer</a>
        </div>
    </div>
</div>

{# ---------------------------------------------------- #}
{# JAVASCRIPT COMPLET DE CENTRALISATION                 #}
{# ---------------------------------------------------- #}
<script>
    // --- GESTION DU CHANGEMENT D'ONGLET (TAB SWITCH) ---
    function switchTab(sectionId) {
        document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.tab-link').forEach(l => l.classList.remove('active'));
        
        document.getElementById(sectionId).classList.add('active');
        event.target.classList.add('active');
    }

    // Liste globale de tous les albums (générée via Twig pour l'affichage discographie artiste)
    const allAlbums = [
        {% for album in albums %}
            {
                id: {{ album.id }},
                title: "{{ album.title|e('js') }}",
                coverUrl: "{{ album.coverUrl|e('js') }}",
                artistId: {{ album.artist.id }}
            },
        {% endfor %}
    ];

    // --- SYSTEME DE RECHERCHE EN TEMPS REEL (JS) ---
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase().trim();
            const albumCards = document.querySelectorAll('#mainAlbumGrid .album-card');

            albumCards.forEach(card => {
                const title = card.getAttribute('data-title');
                const artist = card.getAttribute('data-artist');

                if (title.includes(query) || artist.includes(query)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    }

    // Fonctions d'ouverture/fermeture basiques
    document.getElementById('openModalBtn').addEventListener('click', () => {
        document.getElementById('albumModal').classList.add('active');
    });
    
    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('active');
    }

    // Fermer les modales en cliquant à côté
    document.querySelectorAll('.modal-overlay').forEach(m => {
        m.addEventListener('click', (e) => { if(e.target === m) m.classList.remove('active'); });
    });

    // 1. OUVRIR LES DETAILS D'UN ALBUM
    function openAlbumDetails(album, isConnected) {
        if (!isConnected) {
            window.location.href = "/login";
            return;
        }

        const content = document.getElementById('showAlbumContent');
        
        let reviewsHTML = '';
        if(album.reviews.length === 0) {
            reviewsHTML = '<p style="opacity:0.5;">Aucun avis pour le moment.</p>';
        } else {
            album.reviews.forEach(r => {
                let stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
                reviewsHTML += `
                    <div class="review-card">
                        <div style="display:flex; justify-content:space-between; font-size:14px;">
                            <strong>@${r.user}</strong>
                            <span class="stars">${stars}</span>
                        </div>
                        <p style="margin:5px 0 0 0; opacity:0.9;">${r.text}</p>
                    </div>`;
            });
        }

        content.innerHTML = `
            <button class="close-modal" onclick="closeModal('showAlbumModal')">&times;</button>
            <div class="detail-flex">
                <img class="detail-img" src="${album.coverUrl}" alt="Cover">
                <div style="flex:1;">
                    <h1 style="margin-top:0;">${album.title}</h1>
                    <h3 style="margin-top:0;">Artiste : <span class="artist-clickable-link" onclick="closeModal('showAlbumModal'); openArtistDetails(${album.artistId}, '${album.artistName.replace(/'/g, "\\'")}')">${album.artistName}</span></h3>
                    <hr style="border:0; border-top:1px solid #2a2a2a; margin:20px 0;">
                    <h3>Avis des membres (SQL)</h3>
                    <div style="max-height: 250px; overflow-y:auto;">${reviewsHTML}</div>
                </div>
            </div>
        `;
        
        document.getElementById('showAlbumModal').classList.add('active');
    }

    // 2. OUVRIR LA DISCOGRAPHIE D'UN ARTISTE
    function openArtistDetails(artistId, artistName) {
        document.getElementById('artistModalTitle').innerText = "Discographie de " + artistName;
        const grid = document.getElementById('artistAlbumsGrid');
        grid.innerHTML = ''; 

        const filtered = allAlbums.filter(a => a.artistId === artistId);

        filtered.forEach(a => {
            grid.innerHTML += `
                <div class="album-card" style="cursor:default;">
                    <img src="${a.coverUrl}" style="height:150px;">
                    <h4 style="margin:5px 0 0 0; font-size:14px;">${a.title}</h4>
                </div>
            `;
        });

        document.getElementById('showArtistModal').classList.add('active');
    }
</script>
{% endblock %}