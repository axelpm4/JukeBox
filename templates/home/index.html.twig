{% extends 'base.html.twig' %}

{% block body %}
<style>
    /* Styles globaux */
    body { background-color: #121214; color: white; font-family: sans-serif; margin: 0; padding: 0; }
    .header { display: flex; justify-content: space-between; padding: 20px; align-items: center; }
    .btn-purple { background: #6366f1; color: white; padding: 10px 20px; border-radius: 5px; text-decoration: none; border: none; cursor: pointer; display: inline-block; }
    .import-banner { background: #1a1a1e; border: 1px dashed #333; padding: 40px; border-radius: 15px; text-align: center; margin: 20px; }
    
    /* Grille d'albums */
    .album-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 20px; }
    .album-card { background: #1a1a1e; padding: 10px; border-radius: 10px; cursor: pointer; transition: transform 0.2s; }
    .album-card:hover { transform: scale(1.02); }
    .album-card img { width: 100%; height: 200px; object-fit: cover; border-radius: 8px; }
    
    /* SYSTEME DE MODALES (POP-UPS) */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.8);
        display: flex; justify-content: center; align-items: center;
        z-index: 1000;
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .modal-overlay.active { opacity: 1; pointer-events: auto; }

    .form-container {
        max-width: 800px; width: 90%; max-height: 85vh; overflow-y: auto;
        background: #1a1a1e; padding: 30px; border-radius: 15px;
        position: relative; box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }
    .close-modal { position: absolute; top: 15px; right: 20px; background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; opacity: 0.7; }
    .close-modal:hover { opacity: 1; }

    /* Formulaire styles */
    .field { margin-bottom: 14px; }
    input, select, textarea { width: 100%; background: #121214; color: #fff; padding: 10px; border-radius: 8px; border: 1px solid #2a2a2a; box-sizing: border-box; }
    .row { display: flex; gap: 14px; }
    .row > * { flex: 1; }

    /* Détails Album et Avis */
    .detail-flex { display: flex; gap: 25px; }
    .detail-img { width: 250px; height: 250px; object-fit: cover; border-radius: 10px; }
    .review-card { background: #121214; padding: 12px; border-radius: 8px; margin-top: 10px; border: 1px solid #2a2a2a; }
    .stars { color: #f59e0b; }
    .artist-clickable-link { color: #6366f1; cursor: pointer; text-decoration: underline; }
</style>

<div class="container">
    {# 1. BARRE DE NAVIGATION #}
    <header class="header">
        <div class="logo"><h2>Juke-box</h2></div>
        <div class="search"><input type="text" placeholder="Recherche..."></div>
        <div class="auth-buttons">
            {% if app.user %}
                <span style="margin-right: 15px;">Bonjour {{ app.user.username }}</span>
                <a href="/logout" class="btn-purple">Déconnexion</a>
            {% else %}
                <a href="/login" style="color: white; margin-right: 15px; text-decoration: none;">Connexion</a>
                <a href="/register" class="btn-purple">S'inscrire</a>
            {% endif %}
        </div>
    </header>

    {# 2. ZONE D'IMPORT (Bannière) #}
    <div class="import-banner">
        <p>Ajoutez un album, un artiste ou laissez un avis général</p>
        <button id="openModalBtn" class="btn-purple" style="margin-top: 10px;">Importer un album</button>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 1 : FORMULAIRE D'AJOUT D'ALBUM                #}
    {# ---------------------------------------------------- #}
    <div id="albumModal" class="modal-overlay">
        <div class="form-container">
            <button class="close-modal" onclick="closeModal('albumModal')">&times;</button>
            <h2 style="margin-top:0;">Importer / Ajouter un album</h2>
            <form action="/album/new" method="post">
                <div class="row">
                    <div class="field">
                        <label>Titre</label>
                        <input name="title" type="text" required placeholder="Ex: Random Access Memories" />
                    </div>
                    <div class="field">
                        <label>Date de sortie</label>
                        <input name="release_date" type="date" />
                    </div>
                </div>
                <div class="field">
                    <label>Cover URL</label>
                    <input name="cover_url" type="url" required placeholder="https://..." />
                </div>
                <div class="field">
                    <label>Artiste</label>
                    <select name="artist_id">
                        <option value="">-- Choisir (optionnel) --</option>
                        {% for artist in artists %}
                            <option value="{{ artist.id }}">{{ artist.name }}</option>
                        {% endfor %}
                    </select>
                    <input name="artist_name" type="text" placeholder="Ou créez un artiste : Ex: Daft Punk" style="margin-top: 8px;" />
                </div>
                <hr style="border:0; border-top:1px solid #2a2a2a; margin: 18px 0;" />
                <h3>Laisser un avis (SQL)</h3>
                <div class="row">
                    <div class="field">
                        <label>Note (1-5)</label>
                        <select name="rating" required>
                            <option value="" disabled selected>Choisir une note</option>
                            {% for i in 1..5 %} <option value="{{ i }}">{{ i }}</option> {% endfor %}
                        </select>
                    </div>
                    <div class="field">
                        <label>Texte</label>
                        <textarea name="text" rows="3" placeholder="Votre avis..." required></textarea>
                    </div>
                </div>
                <button type="submit" class="btn-purple" style="margin-top: 10px;">Créer et Ajouter l'album</button>
            </form>
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 2 : DETAILS DE L'ALBUM ET SES AVIS (DYNAMIQUE)#}
    {# ---------------------------------------------------- #}
    <div id="showAlbumModal" class="modal-overlay">
        <div class="form-container" id="showAlbumContent">
            <button class="close-modal" onclick="closeModal('showAlbumModal')">&times;</button>
            {# Rempli dynamiquement par JS #}
        </div>
    </div>

    {# ---------------------------------------------------- #}
    {# MODALE 3 : DISCOGRAPHIE DE L'ARTISTE (DYNAMIQUE)     #}
    {# ---------------------------------------------------- #}
    <div id="showArtistModal" class="modal-overlay">
        <div class="form-container">
            <button class="close-modal" onclick="closeModal('showArtistModal')">&times;</button>
            <h2 id="artistModalTitle" style="margin-top:0;"></h2>
            <h3>Discographie</h3>
            <div class="album-grid" id="artistAlbumsGrid" style="padding:0;">
                {# Rempli dynamiquement par JS #}
            </div>
        </div>
    </div>


    {# 3. SECTION TENDANCES (Avis récents) #}
    <h3 style="margin-left: 20px;">Avis récent</h3>
    <div class="album-grid">
        {% for album in albums %}
            {# On stocke les données de l'album en JSON dans HTML pour que le JS puisse les lire facilement #}
            <div class="album-card" onclick="openAlbumDetails({{ {
                id: album.id,
                title: album.title,
                coverUrl: album.coverUrl,
                artistId: album.artist.id,
                artistName: album.artist.name,
                reviews: album.reviews|map(r => {id: r.id, user: r.user.username, rating: r.rating, text: r.text})
            }|json_encode|e('html_attr') }}, {{ app.user ? 'true' : 'false' }})">
                
                <img src="{{ album.coverUrl }}" alt="Cover">
                <h4>{{ album.title }}</h4>
                <p style="opacity: 0.7; margin: 5px 0 0 0;">Par : <span class="artist-clickable-link">{{ album.artist.name }}</span></p>
                
                {% if is_granted('ROLE_ADMIN') %}
                    <button style="color: red; background: none; border: none; cursor: pointer; margin-top: 10px;">Supprimer</button>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>

{# ---------------------------------------------------- #}
{# JAVASCRIPT DE CENTRALISATION SPECIALE SINGLE-PAGE    #}
{# ---------------------------------------------------- #}
<script>
    // Liste globale de tous les albums (générée via Twig pour l'affichage artiste)
    const allAlbums = [
        {% for album in albums %}
            {
                id: {{ album.id }},
                title: "{{ album.title|e('js') }}",
                coverUrl: "{{ album.coverUrl|e('js') }}",
                artistId: {{ album.artist.id }}
            },
        {% endfor %}
    ];

    // Fonctions d'ouverture/fermeture basiques
    document.getElementById('openModalBtn').addEventListener('click', () => {
        document.getElementById('albumModal').classList.add('active');
    });
    
    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('active');
    }

    // Fermer les modales en cliquant à côté
    document.querySelectorAll('.modal-overlay').forEach(m => {
        m.addEventListener('click', (e) => { if(e.target === m) m.classList.remove('active'); });
    });

    // 1. OUVRIR LES DETAILS D'UN ALBUM
    function openAlbumDetails(album, isConnected) {
        // Si pas connecté -> Redirection vers la page de login
        if (!isConnected) {
            window.location.href = "/login";
            return;
        }

        const content = document.getElementById('showAlbumContent');
        
        // Génération des étoiles et avis en HTML pur via JS
        let reviewsHTML = '';
        if(album.reviews.length === 0) {
            reviewsHTML = '<p style="opacity:0.5;">Aucun avis pour le moment.</p>';
        } else {
            album.reviews.forEach(r => {
                let stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
                reviewsHTML += `
                    <div class="review-card">
                        <div style="display:flex; justify-content:space-between; font-size:14px;">
                            <strong>@${r.user}</strong>
                            <span class="stars">${stars}</span>
                        </div>
                        <p style="margin:5px 0 0 0; opacity:0.9;">${r.text}</p>
                    </div>`;
            });
        }

        // Remplissage de la modale de détails
        content.innerHTML = `
            <button class="close-modal" onclick="closeModal('showAlbumModal')">&times;</button>
            <div class="detail-flex">
                <img class="detail-img" src="${album.coverUrl}" alt="Cover">
                <div style="flex:1;">
                    <h1 style="margin-top:0;">${album.title}</h1>
                    <h3 style="margin-top:0;">Artiste : <span class="artist-clickable-link" onclick="closeModal('showAlbumModal'); openArtistDetails(${album.artistId}, '${album.artistName.replace(/'/g, "\\'")}')">${album.artistName}</span></h3>
                    <hr style="border:0; border-top:1px solid #2a2a2a; margin:20px 0;">
                    <h3>Avis des membres (SQL)</h3>
                    <div style="max-height: 250px; overflow-y:auto;">${reviewsHTML}</div>
                </div>
            </div>
        `;
        
        document.getElementById('showAlbumModal').classList.add('active');
    }

    // 2. OUVRIR LA DISCOGRAPHIE D'UN ARTISTE
    function openArtistDetails(artistId, artistName) {
        document.getElementById('artistModalTitle').innerText = "Discographie de " + artistName;
        const grid = document.getElementById('artistAlbumsGrid');
        grid.innerHTML = ''; // Clear

        // Filtrer les albums appartenant à cet artiste
        const filtered = allAlbums.filter(a => a.artistId === artistId);

        filtered.forEach(a => {
            grid.innerHTML += `
                <div class="album-card" style="cursor:default;">
                    <img src="${a.coverUrl}" style="height:150px;">
                    <h4 style="margin:5px 0 0 0; font-size:14px;">${a.title}</h4>
                </div>
            `;
        });

        document.getElementById('showArtistModal').classList.add('active');
    }
</script>
{% endblock %}